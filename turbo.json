{
  "$schema": "https://v2-10-2.turborepo.dev/schema.json",
  "concurrency": "20",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**",
        ".open-next/**",
        ".output/**",
        ".nuxt/**",
        ".react-router/**",
        ".source/**",
        ".svelte-kit/**",
        "build/**"
      ]
    },
    "types:check": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    },
    "conformance:durable-streams": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "conformance:durable-streams:freshness": {
      "cache": false,
      "env": ["DURABLE_STREAMS_REPO"]
    }
  }
}
