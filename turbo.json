{
  "$schema": "https://v2-9-14.turborepo.dev/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**",
        ".open-next/**",
        ".output/**",
        ".nuxt/**",
        ".react-router/**",
        ".source/**",
        ".svelte-kit/**",
        "build/**"
      ]
    },
    "types:check": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "persistent": true,
      "cache": false
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": [],
      "env": ["FRAGNO_DYNAMODB_ENDPOINT", "AWS_REGION"],
      "passThroughEnv": ["AWS_ACCESS_KEY_ID", "AWS_SECRET_ACCESS_KEY"]
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "outputs": []
    }
  }
}
