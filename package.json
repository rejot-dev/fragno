{
  "name": "@fragno-dev/root",
  "private": true,
  "homepage": "https://fragno.dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rejot-dev/fragno.git"
  },
  "scripts": {
    "dev": "turbo watch --ui tui --concurrency 20 dev",
    "cli": "tsx apps/fragno-cli/src/cli.ts",
    "dev+": "turbo watch --ui tui --concurrency 20 dev types:check",
    "format": "pnpm exec oxfmt && pnpm exec prettier --config prettier.unsupported.config.mjs --write \"**/*.{astro,svelte,sql}\"",
    "format:check": "pnpm exec oxfmt --check && pnpm exec prettier --config prettier.unsupported.config.mjs --check \"**/*.{astro,svelte,sql}\"",
    "format:changed": "node scripts/format-files.mjs --changed",
    "lint": "oxlint .",
    "lint:type-aware": "oxlint --type-aware .",
    "lint:type-aware-fix": "oxlint --fix --type-aware .",
    "lint:fix": "oxlint --fix .",
    "clean": "find . -type d \\( -name dist -o -name node_modules -o -name .turbo -o -name .next -o -name .output -o -name .nuxt -o -name .react-router -o -name .open-next -o -name .source -o -name .svelte-kit -o -name .tanstack \\) -prune -exec rm -rf {} + -o -name tsconfig.tsbuildinfo -o -name coverage.json -exec rm -f {} +",
    "clean:install": "pnpm run clean && pnpm install",
    "build": "turbo run build",
    "build:fast": "turbo run build --output-logs=errors-only --filter='...[main...HEAD]' --filter='./packages/**'",
    "build:watch": "turbo watch build --filter='./packages/**'",
    "build:watch:10m": "bash -c \"while true; do pnpm run build:watch & pid=$!; (sleep 600 && kill \\\"$pid\\\" 2>/dev/null) & wait $pid; echo 'Restarting...'; done\"",
    "build:ui": "turbo watch --ui tui build",
    "build:clean": "turbo run build --force",
    "types:check": "turbo run types:check --output-logs=errors-only",
    "types:check:watch": "turbo watch types:check",
    "test": "turbo run test --output-logs=errors-only",
    "test:watch": "turbo run test:watch --output-logs=errors-only",
    "test:coverage": "turbo run test && turbo run collect-json-reports merge-json-reports report --filter=@fragno-private/vitest-config",
    "fallow:audit": "fallow audit --root . --config \"$PWD/.fallowrc.jsonc\" --changed-since HEAD --summary --fail-on-issues",
    "fallow:dead-code": "fallow dead-code --root . --config .fallowrc.jsonc --summary",
    "fallow:dupes": "fallow dupes --root . --config .fallowrc.jsonc --summary",
    "fallow:health": "fallow health --root . --config .fallowrc.jsonc --summary",
    "ci:version": "changeset version && pnpm update && pnpm install && pnpm exec oxfmt pnpm-workspace.yaml",
    "ci:publish": "changeset publish && changeset tag && pnpm exec oxfmt pnpm-workspace.yaml",
    "ci:canary": "changeset version --snapshot ${CANARY_SUFFIX:-canary} && changeset publish --tag canary --no-git-tag",
    "diff:lockfile": "git -c core.attributesfile=/dev/null --no-pager diff --text pnpm-lock.yaml",
    "link:global": "pnpm -r --workspace-concurrency=1 --filter \"./packages/**\" exec -- node ../../scripts/link-global.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@nanostores/query": "^0.3.4",
    "fallow": "^2.104.0",
    "lefthook": "^1.13.6",
    "nanostores": "^1.4.1",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.75.0",
    "oxlint-tsgolint": "^0.23.0",
    "prettier": "3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-sql": "^0.19.2",
    "prettier-plugin-svelte": "^3.5.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tsdown": "^0.22.13",
    "tsx": "^4.23.1",
    "turbo": "^2.10.6",
    "typescript": "catalog:",
    "typescript-7": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": "^22.22.0 || >=24.11.0"
  },
  "packageManager": "pnpm@11.1.3"
}
