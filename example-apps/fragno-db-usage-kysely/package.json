{
  "name": "@fragno-dev/fragno-db-usage-kysely",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/rejot-dev/fragno.git",
    "directory": "example-apps/fragno-db-usage-kysely"
  },
  "type": "module",
  "main": "./dist/node/mod.js",
  "module": "./dist/node/mod.js",
  "types": "./dist/node/mod.d.ts",
  "exports": {
    ".": {
      "types": "./dist/mod.d.ts",
      "default": "./dist/mod.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "types:check": "tsgo --noEmit",
    "db:migrate": "pnpm run db:migrate:kysely && pnpm run db:migrate:fragno",
    "db:migrate:kysely": "kysely migrate up",
    "db:generate:fragno": "fragno-cli db generate ./src/fragno/comment-fragment.ts ./src/fragno/rating-fragment.ts -o ./migrations",
    "db:migrate:fragno": "fragno-cli db migrate ./src/fragno/comment-fragment.ts ./src/fragno/rating-fragment.ts",
    "db:generate": "fragno-cli db generate ./src/fragno/comment-fragment.ts ./src/fragno/rating-fragment.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.3.15",
    "@fragno-dev/db": "workspace:*",
    "@fragno-dev/fragno-db-library": "workspace:*",
    "gunshi": "^0.26.3",
    "kysely": "^0.28.10",
    "kysely-pglite": "^0.6.1",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@fragno-dev/cli": "workspace:*",
    "@fragno-private/typescript-config": "workspace:*",
    "@fragno-private/vitest-config": "workspace:*",
    "@types/node": "^22.19.7",
    "@vitest/coverage-istanbul": "^4.1.0",
    "kysely-ctl": "^0.19.0",
    "vitest": "catalog:"
  }
}
