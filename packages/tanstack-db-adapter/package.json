{
  "name": "@fragno-dev/tanstack-db-adapter",
  "version": "0.0.0",
  "description": "Ingest Fragno database outboxes into TanStack DB collections",
  "homepage": "https://fragno.dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rejot-dev/fragno.git",
    "directory": "packages/tanstack-db-adapter"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/collection-options.js",
  "module": "./dist/collection-options.js",
  "types": "./dist/collection-options.d.ts",
  "exports": {
    ".": {
      "types": "./dist/collection-options.d.ts",
      "default": "./dist/collection-options.js"
    },
    "./checkpoint": {
      "types": "./dist/checkpoint.d.ts",
      "default": "./dist/checkpoint.js"
    },
    "./coordinator": {
      "types": "./dist/coordinator.d.ts",
      "default": "./dist/coordinator.js"
    },
    "./persistence": {
      "types": "./dist/persistence.d.ts",
      "default": "./dist/persistence.js"
    },
    "./protocol": {
      "types": "./dist/protocol.d.ts",
      "default": "./dist/protocol.js"
    },
    "./transport": {
      "types": "./dist/transport.d.ts",
      "default": "./dist/transport.js"
    },
    "./scenario": {
      "types": "./dist/scenario.d.ts",
      "default": "./dist/scenario.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "lint": "oxlint .",
    "types:check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@fragno-dev/db": "workspace:*",
    "@standard-schema/spec": "^1.1.0",
    "@tanstack/db-sqlite-persistence-core": "0.2.8",
    "superjson": "^2.2.1"
  },
  "devDependencies": {
    "@fragno-dev/core": "workspace:*",
    "@fragno-dev/test": "workspace:*",
    "@fragno-private/typescript-config": "workspace:*",
    "@fragno-private/vitest-config": "workspace:*",
    "@tanstack/db": "0.6.16",
    "@tanstack/node-db-sqlite-persistence": "0.2.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.7",
    "@vitest/coverage-istanbul": "^4.1.0",
    "better-sqlite3": "^12.6.2",
    "tsdown": "^0.22.4",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@fragno-dev/core": "^0.2.2",
    "@fragno-dev/test": "^2.0.0",
    "@tanstack/db": "^0.6.16",
    "@tanstack/node-db-sqlite-persistence": "^0.2.8",
    "better-sqlite3": "^12.6.2"
  },
  "peerDependenciesMeta": {
    "@fragno-dev/core": {
      "optional": true
    },
    "@fragno-dev/test": {
      "optional": true
    },
    "@tanstack/node-db-sqlite-persistence": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    }
  }
}
