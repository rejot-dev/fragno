{
  "name": "@fragno-dev/pi-fragment",
  "version": "1.0.0",
  "description": "A Fragno fragment",
  "keywords": [
    "fragno",
    "react",
    "solidjs",
    "svelte",
    "typescript",
    "vue"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rejot-dev/fragno.git",
    "directory": "packages/pi-fragment"
  },
  "bin": {
    "fragno-pi": "./bin/run.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "type": "module",
  "main": "./dist/node/index.js",
  "module": "./dist/node/index.js",
  "types": "./dist/node/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "default": "./dist/node/index.js"
    },
    "./cli": {
      "types": "./dist/cli/mod.d.ts",
      "default": "./dist/cli/mod.js"
    },
    "./route-schemas": {
      "types": "./dist/node/pi/route-schemas.d.ts",
      "browser": "./dist/browser/pi/route-schemas.js",
      "default": "./dist/node/pi/route-schemas.js"
    },
    "./skills": {
      "types": "./dist/node/pi/skills.d.ts",
      "default": "./dist/node/pi/skills.js"
    },
    "./react": {
      "types": "./dist/browser/client/react.d.ts",
      "default": "./dist/browser/client/react.js"
    },
    "./vue": {
      "types": "./dist/browser/client/vue.d.ts",
      "default": "./dist/browser/client/vue.js"
    },
    "./svelte": {
      "types": "./dist/browser/client/svelte.d.ts",
      "default": "./dist/browser/client/svelte.js"
    },
    "./solid": {
      "types": "./dist/browser/client/solid.d.ts",
      "default": "./dist/browser/client/solid.js"
    },
    "./vanilla": {
      "types": "./dist/browser/client/vanilla.d.ts",
      "default": "./dist/browser/client/vanilla.js"
    }
  },
  "scripts": {
    "types:check": "tsc --noEmit",
    "build": "tsdown",
    "test": "vitest run",
    "cli": "tsx src/cli/cli.ts"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.75.4",
    "@earendil-works/pi-ai": "^0.75.4",
    "@fragno-dev/core": "workspace:*",
    "@fragno-dev/db": "workspace:*",
    "@fragno-dev/workflows": "workspace:*",
    "@standard-schema/spec": "^1.1.0",
    "nanostores": "^1.2.0",
    "typebox": "^1.1.38",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@fragno-dev/cli": "workspace:*",
    "@fragno-dev/test": "workspace:*",
    "@fragno-dev/unplugin-fragno": "workspace:*",
    "@types/node": "^25.2.2",
    "@types/react": "catalog:",
    "drizzle-kit": "^0.31.7",
    "drizzle-orm": "^0.44.7",
    "tsdown": "^0.22.4",
    "tsx": "^4.21.0",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "solid-js": ">=1.0.0",
    "svelte": ">=4.0.0",
    "typescript": "catalog:",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  }
}
