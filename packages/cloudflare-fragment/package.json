{
  "name": "@fragno-dev/cloudflare-fragment",
  "version": "0.0.3",
  "description": "Fragno Cloudflare Workers for Platforms deployment fragment",
  "keywords": [
    "fragno",
    "react",
    "solidjs",
    "svelte",
    "typescript",
    "vue"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rejot-dev/fragno.git",
    "directory": "packages/cloudflare-fragment"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/node/index.js",
  "module": "./dist/node/index.js",
  "types": "./dist/node/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/node/index.d.ts",
      "default": "./dist/node/index.js"
    },
    "./react": {
      "types": "./dist/browser/client/react.d.ts",
      "default": "./dist/browser/client/react.js"
    },
    "./vue": {
      "types": "./dist/browser/client/vue.d.ts",
      "default": "./dist/browser/client/vue.js"
    },
    "./svelte": {
      "types": "./dist/browser/client/svelte.d.ts",
      "default": "./dist/browser/client/svelte.js"
    },
    "./solid": {
      "types": "./dist/browser/client/solid.d.ts",
      "default": "./dist/browser/client/solid.js"
    },
    "./vanilla": {
      "types": "./dist/browser/client/vanilla.d.ts",
      "default": "./dist/browser/client/vanilla.js"
    },
    "./script-name": {
      "types": "./dist/node/script-name.d.ts",
      "default": "./dist/node/script-name.js"
    }
  },
  "scripts": {
    "types:check": "tsc --noEmit",
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@fragno-dev/core": "workspace:*",
    "@fragno-dev/db": "workspace:*",
    "@standard-schema/spec": "^1.1.0",
    "cloudflare": "^5.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@fragno-dev/cli": "workspace:*",
    "@fragno-dev/test": "workspace:*",
    "@fragno-dev/unplugin-fragno": "workspace:*",
    "@types/node": "^25.2.2",
    "tsdown": "^0.22.4",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "solid-js": ">=1.0.0",
    "svelte": ">=4.0.0",
    "typescript": ">=5",
    "vue": ">=3.0.0"
  }
}
