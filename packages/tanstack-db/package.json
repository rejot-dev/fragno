{
  "name": "@fragno-dev/tanstack-db",
  "version": "0.0.1",
  "description": "Server-authoritative TanStack DB collections synchronized through the Durable Streams State Protocol",
  "homepage": "https://fragno.dev",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rejot-dev/fragno.git",
    "directory": "packages/tanstack-db"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/stream-db.d.ts",
      "default": "./dist/stream-db.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "build:watch": "tsdown --watch",
    "types:check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@durable-streams/client": "^0.2.6",
    "@durable-streams/state": "0.3.1",
    "@fragno-dev/db": "workspace:*",
    "@standard-schema/spec": "^1.1.0",
    "@tanstack/db": "0.6.16",
    "@tanstack/db-sqlite-persistence-core": "0.2.8"
  },
  "devDependencies": {
    "@fragno-dev/core": "workspace:*",
    "@fragno-dev/test": "workspace:*",
    "@fragno-private/typescript-config": "workspace:*",
    "@fragno-private/vitest-config": "workspace:*",
    "@tanstack/node-db-sqlite-persistence": "0.2.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.7",
    "better-sqlite3": "^12.10.0",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
