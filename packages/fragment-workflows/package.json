      "types": "./dist/node/workflow.d.ts",
      "default": "./dist/node/workflow.js"
    },
    "./debug-log": {
      "types": "./dist/node/debug-log.d.ts",
      "default": "./dist/node/debug-log.js"
    },
    "./stream-step-emissions": {
      "types": "./dist/node/stream-step-emissions.d.ts",
      "default": "./dist/node/stream-step-emissions.js"
    },
    "./step-identity": {
      "types": "./dist/node/step-identity.d.ts",
      "default": "./dist/node/step-identity.js"
    },
    "./remote-workflow": {
      "types": "./dist/node/remote-workflow.d.ts",
      "default": "./dist/node/remote-workflow.js"
    },
    "./instance-ref": {
      "types": "./dist/node/instance-ref.d.ts",
      "default": "./dist/node/instance-ref.js"
    },
    "./step-live-pump": {
      "types": "./dist/node/runner/step-live-pump.d.ts",
      "default": "./dist/node/runner/step-live-pump.js"
    },
    "./client": {
      "types": "./dist/browser/client/clients.d.ts",
      "default": "./dist/browser/client/clients.js"
    },
    "./react": {
      "types": "./dist/browser/client/react.d.ts",
      "default": "./dist/browser/client/react.js"
    },
    "./vue": {
      "types": "./dist/browser/client/vue.d.ts",
      "default": "./dist/browser/client/vue.js"
    },
    "./svelte": {
      "types": "./dist/browser/client/svelte.d.ts",
      "default": "./dist/browser/client/svelte.js"
    },
    "./solid": {
      "types": "./dist/browser/client/solid.d.ts",
      "default": "./dist/browser/client/solid.js"
    },
    "./vanilla": {
      "types": "./dist/browser/client/vanilla.d.ts",
      "default": "./dist/browser/client/vanilla.js"
    },
    "./test": {
      "types": "./dist/node/test.d.ts",
      "default": "./dist/node/test.js"
    },
    "./scenario": {
      "types": "./dist/node/scenario.d.ts",
      "default": "./dist/node/scenario.js"
    }
  },
  "scripts": {
    "types:check": "tsgo --noEmit",
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@fragno-dev/core": "workspace:*",
    "@fragno-dev/db": "workspace:*",
    "nanostores": "^1.2.0",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@fragno-dev/test": "workspace:*",
    "@fragno-dev/unplugin-fragno": "workspace:*",
    "@fragno-private/typescript-config": "workspace:*",
    "@fragno-private/vitest-config": "workspace:*",
    "@types/node": "^22",
    "@vitest/coverage-istanbul": "^4.1.0",
    "tsdown": "^0.15.12",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "@typescript/native-preview": "catalog:",
    "react": ">=18.0.0",
    "solid-js": ">=1.0.0",
