{
  "name": "@fragno-dev/pi-harness",
  "version": "0.0.3",
  "description": "A Fragno fragment for Pi workflow session harnessing",
  "keywords": [
    "fragno",
    "react",
    "solidjs",
    "svelte",
    "typescript",
    "vue"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rejot-dev/fragno.git",
    "directory": "packages/pi-harness"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    "./client": {
      "types": "./dist/browser/client/clients.d.ts",
      "default": "./dist/browser/client/clients.js"
    },
    "./client/pi-workflow-emission-stream": {
      "types": "./dist/browser/client/pi-workflow-emission-stream.d.ts",
      "default": "./dist/browser/client/pi-workflow-emission-stream.js"
    },
    "./client/workflow-lofi-session-projection": {
      "types": "./dist/browser/client/workflow-lofi-session-projection.d.ts",
      "default": "./dist/browser/client/workflow-lofi-session-projection.js"
    },
    "./definition": {
      "types": "./dist/node/pi/definition.d.ts",
      "default": "./dist/node/pi/definition.js"
    },
    "./factory": {
      "types": "./dist/node/pi/factory.d.ts",
      "default": "./dist/node/pi/factory.js"
    },
    "./harness/commands": {
      "types": "./dist/node/pi/harness/commands.d.ts",
      "default": "./dist/node/pi/harness/commands.js"
    },
    "./harness/execution-env": {
      "types": "./dist/node/pi/harness/execution-env.d.ts",
      "default": "./dist/node/pi/harness/execution-env.js"
    },
    "./harness/run-pi-harness-step": {
      "types": "./dist/node/pi/harness/run-pi-harness-step.d.ts",
      "default": "./dist/node/pi/harness/run-pi-harness-step.js"
    },
    "./harness/session-storage": {
      "types": "./dist/node/pi/harness/session-storage.d.ts",
      "default": "./dist/node/pi/harness/session-storage.js"
    },
    "./react": {
      "types": "./dist/browser/client/react.d.ts",
      "default": "./dist/browser/client/react.js"
    },
    "./pi-jsonl-export": {
      "types": "./dist/node/pi/pi-jsonl-export.d.ts",
      "default": "./dist/node/pi/pi-jsonl-export.js"
    },
    "./route-schemas": {
      "types": "./dist/node/pi/route-schemas.d.ts",
      "browser": "./dist/browser/pi/route-schemas.js",
      "default": "./dist/node/pi/route-schemas.js"
    },
    "./routes": {
      "types": "./dist/node/routes.d.ts",
      "default": "./dist/node/routes.js"
    },
    "./schema": {
      "types": "./dist/node/schema.d.ts",
      "default": "./dist/node/schema.js"
    },
    "./skills": {
      "types": "./dist/node/pi/skills.d.ts",
      "default": "./dist/node/pi/skills.js"
    },
    "./solid": {
      "types": "./dist/browser/client/solid.d.ts",
      "default": "./dist/browser/client/solid.js"
    },
    "./svelte": {
      "types": "./dist/browser/client/svelte.d.ts",
      "default": "./dist/browser/client/svelte.js"
    },
    "./tools": {
      "types": "./dist/node/pi/tools.d.ts",
      "default": "./dist/node/pi/tools.js"
    },
    "./types": {
      "types": "./dist/node/pi/types.d.ts",
      "default": "./dist/node/pi/types.js"
    },
    "./workflow-session-projection": {
      "types": "./dist/browser/pi/workflow-session-projection.d.ts",
      "browser": "./dist/browser/pi/workflow-session-projection.js",
      "default": "./dist/node/pi/workflow-session-projection.js"
    },
    "./vanilla": {
      "types": "./dist/browser/client/vanilla.d.ts",
      "default": "./dist/browser/client/vanilla.js"
    },
    "./vue": {
      "types": "./dist/browser/client/vue.d.ts",
      "default": "./dist/browser/client/vue.js"
    },
    "./workflows/interactive-chat-workflow": {
      "types": "./dist/node/pi/workflows/interactive-chat-workflow.d.ts",
      "default": "./dist/node/pi/workflows/interactive-chat-workflow.js"
    }
  },
  "scripts": {
    "types:check": "tsc --noEmit",
    "build": "tsdown",
    "test": "vitest run"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.75.4",
    "@earendil-works/pi-ai": "^0.75.4",
    "@fragno-dev/core": "workspace:*",
    "@fragno-dev/db": "workspace:*",
    "@fragno-dev/lofi": "workspace:*",
    "@fragno-dev/workflows": "workspace:*",
    "@standard-schema/spec": "^1.1.0",
    "nanostores": "^1.2.0",
    "typebox": "^1.1.38",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@fragno-dev/test": "workspace:*",
    "@fragno-dev/unplugin-fragno": "workspace:*",
    "@types/node": "^25.2.2",
    "@types/react": "catalog:",
    "drizzle-kit": "^0.31.7",
    "drizzle-orm": "^0.44.7",
    "fake-indexeddb": "^6.2.5",
    "tsdown": "^0.22.4",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "solid-js": ">=1.0.0",
    "svelte": ">=4.0.0",
    "typescript": "catalog:",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "svelte": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "solid-js": {
      "optional": true
    }
  }
}
