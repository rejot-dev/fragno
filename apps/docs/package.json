{
  "name": "@fragno-dev/docs-rr",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "cloudflare:debug-worker": "tsx scripts/upload-debug-dispatch-worker.ts",
    "generate:og": "tsx scripts/generate-og-images.tsx",
    "deploy": "pnpm run build && wrangler deploy",
    "dev": "react-router dev",
    "postinstall": "fumadocs-mdx",
    "preview": "pnpm run build && vite preview",
    "types:check": "tsgo -b --noEmit",
    "types:generate": "wrangler types --env-interface CloudflareEnv --env-file .dev.vars.example && react-router typegen && fumadocs-mdx",
    "db:fragno:generate": "fragno-cli db generate app/fragno/mailing-list.ts -o app/db/mailing-list-do.schema.ts && fragno-cli db generate app/fragno/forms.ts -o app/db/forms-do.schema.ts",
    "db:mailing-list-do:generate": "drizzle-kit generate --config mailing-list-do.drizzle.config.ts",
    "db:forms-do:generate": "drizzle-kit generate --config forms-do.drizzle.config.ts",
    "shadcn:generate": "tsx app/components/form-builder/generate-registry.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@cfworker/json-schema": "^4.1.1",
    "@cloudflare/sandbox": "^0.7.12",
    "@fragno-dev/auth": "workspace:*",
    "@fragno-dev/cloudflare-fragment": "workspace:*",
    "@fragno-dev/core": "workspace:*",
    "@fragno-dev/db": "workspace:*",
    "@fragno-dev/forms": "workspace:*",
    "@fragno-dev/fragment-mailing-list": "workspace:*",
    "@fragno-dev/github-app-fragment": "workspace:*",
    "@fragno-dev/jsonforms-shadcn-renderers": "workspace:*",
    "@fragno-dev/otp-fragment": "workspace:*",
    "@fragno-dev/pi-fragment": "workspace:*",
    "@fragno-dev/resend-fragment": "workspace:*",
    "@fragno-dev/telegram-fragment": "workspace:*",
    "@fragno-dev/upload": "workspace:*",
    "@fragno-dev/workflows": "workspace:*",
    "@jsonforms/core": "^3.7.0",
    "@jsonforms/react": "^3.7.0",
    "@mariozechner/pi-agent-core": "^0.51.6",
    "@mariozechner/pi-ai": "^0.51.6",
    "@marsidev/react-turnstile": "^1.4.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
