    "@cloudflare/workers-types": "^4.20260301.1",
    "@fragno-dev/test": "workspace:*",
    "@fragno-private/vitest-config": "workspace:*",
    "@react-router/dev": "^7.12.0",
    "@resvg/resvg-js": "^2.6.2",
