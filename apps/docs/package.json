    "@radix-ui/react-tabs": "^1.1.13",
    "@react-router/node": "^7.12.0",
    "@react-router/serve": "^7.12.0",
    "aws4fetch": "^1.0.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.44.7",
    "embla-carousel-react": "^8.6.0",
    "fumadocs-core": "16.6.9",
    "fumadocs-mdx": "14.2.9",
